{
  "name": "@mockholm/zapster",
  "version": "1.0.0",
  "description": "CLI tool for OWASP ZAP API integration",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "zapster": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "zap:version": "ts-node src/index.ts getVersion",
    "baseScan": "ts-node src/index.ts baseScan",
    "spiderScan": "ts-node src/index.ts baseScan",
    "passiveScan": "ts-node src/index.ts passiveScan",
    "activeScan": "ts-node src/index.ts activeScan",
    "ajaxScan": "ts-node src/index.ts ajaxScan",
    "apiScan": "ts-node src/index.ts apiScan",
    "getReport": "ts-node src/index.ts getReport",
    "getPdf": "ts-node src/index.ts getPdf",
    "getAlerts": "ts-node src/index.ts getAlerts",
    "getLogs": "ts-node src/index.ts getLogs",
    "getDockerLog": "ts-node src/index.ts getDockerLog",
    "createJUnitResults": "ts-node src/index.ts createJUnitResults",
    "createTestResult": "ts-node src/index.ts createTestResult",
    "createWorkItem": "ts-node src/index.ts createWorkItem",
    "createExcelReport": "ts-node src/index.ts createExcelReport",
    "configureRules": "ts-node src/index.ts configureRules",
    "automate": "ts-node src/index.ts automate",
    "docker-baseline-scan": "ts-node src/index.ts docker baseline-scan",
    "docker-full-scan": "ts-node src/index.ts docker full-scan",
    "docker-api-scan": "ts-node src/index.ts docker api-scan",
    "docker-pull": "ts-node src/index.ts docker pull"
  },
  "keywords": [
    "zap",
    "owasp",
    "security",
    "scanner",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cli-progress": "^3.12.0",
    "dockerode": "^4.0.10",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "playwright": "^1.58.2",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.3.4",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.10.0",
    "@types/tar-fs": "^2.0.4",
    "@types/yargs": "^17.0.32",
    "tar-fs": "^3.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
