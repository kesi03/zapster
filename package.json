{
  "name": "@mockholm/zapr",
  "version": "1.0.2",
  "description": "CLI tool for OWASP ZAP API integration",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "zapr": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "zap:version": "ts-node src/index.ts zap get-version",
    "zap:base-scan": "ts-node src/index.ts zap base-scan",
    "zap:spider-scan": "ts-node src/index.ts zap base-scan",
    "zap:passive-scan": "ts-node src/index.ts zap passive-scan",
    "zap:active-scan": "ts-node src/index.ts zap active-scan",
    "zap:ajax-scan": "ts-node src/index.ts zap ajax-scan",
    "zap:api-scan": "ts-node src/index.ts zap api-scan",
    "zap:get-report": "ts-node src/index.ts zap get-report",
    "zap:get-alerts": "ts-node src/index.ts zap get-alerts",
    "utils:get-logs": "ts-node src/index.ts utils get-logs",
    "zap:urlOpen": "ts-node src/index.ts zap urlOpen",
    "zap:session": "ts-node src/index.ts zap session",
    "zap:context": "ts-node src/index.ts zap context",
    "zap:users": "ts-node src/index.ts zap users",
    "zap:search": "ts-node src/index.ts zap search",
    "zap:forced-browse": "ts-node src/index.ts zap forced-browse",
    "zap:http-sessions": "ts-node src/index.ts zap http-sessions",
    "zap:break": "ts-node src/index.ts zap break",
    "zap:proxy": "ts-node src/index.ts zap proxy",
    "zap:configure-rules": "ts-node src/index.ts zap configure-rules",
    "zap:automate": "ts-node src/index.ts zap automate",
    "zap:generate-plan": "ts-node src/index.ts zap generate-plan",
    "utils:get-pdf": "ts-node src/index.ts utils get-pdf",
    "utils:create-junit-results": "ts-node src/index.ts utils create-junit-results",
    "azdo:create-test-result": "ts-node src/index.ts azdo create-test-result",
    "azdo:create-work-item": "ts-node src/index.ts azdo create-work-item",
    "utils:create-excel-report": "ts-node src/index.ts utils create-excel-report",
    "docker:baseline-scan": "ts-node src/index.ts docker baseline-scan",
    "docker:full-scan": "ts-node src/index.ts docker full-scan",
    "docker:api-scan": "ts-node src/index.ts docker api-scan",
    "docker:automate": "ts-node src/index.ts docker automate",
    "docker:pull": "ts-node src/index.ts docker pull",
    "docker:get-docker-log": "ts-node src/index.ts docker get-docker-log",
    "docker:start-daemon": "ts-node src/index.ts docker start-daemon",
    "docker:stop-daemon": "ts-node src/index.ts docker stop-daemon",
    "daemon:start": "ts-node src/index.ts daemon start",
    "daemon:stop": "ts-node src/index.ts daemon stop",
    "daemon:status": "ts-node src/index.ts daemon status",
    "daemon:log": "ts-node src/index.ts daemon log",
    "daemon:ping": "ts-node src/index.ts daemon ping",
    "daemon:health": "ts-node src/index.ts daemon health",
    "daemon:started": "ts-node src/index.ts daemon started"
  },
  "keywords": [
    "zap",
    "owasp",
    "security",
    "scanner",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@types/dockerode": "^4.0.1",
    "axios": "^1.6.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "dockerode": "^4.0.10",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "fs-extra": "^11.3.4",
    "playwright": "^1.58.2",
    "pm2": "^6.0.14",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.3.4",
    "yargs": "^17.7.2",
    "zap-cdk": "^0.0.11"
  },
  "devDependencies": {
    "@mockholm/zap-downloader": "^1.0.5",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "@types/tar-fs": "^2.0.4",
    "@types/yargs": "^17.0.32",
    "tar-fs": "^3.1.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
